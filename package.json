{
  "name": "ogrodzenia-app",
  "version": "1.0.0",
  "private": true,
  "main": "expo/AppEntry.js",
  "scripts": {
    "start": "expo start",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "web": "expo start --web",
    "check": "tsc --noEmit",
    "export:android": "expo export --platform android --output-dir .expo-export --max-workers 1 --no-minify --no-bytecode",
    "export:ios": "expo export --platform ios --output-dir .expo-export-ios --max-workers 1 --no-minify --no-bytecode",
    "check:node-spawn": "node scripts/check-node-spawn.js",
    "patch:eas-windows": "node scripts/patch-eas-windows.js",
    "build:android:apk": "npm run patch:eas-windows && eas build --platform android --profile preview",
    "build:ios:preview": "npm run patch:eas-windows && eas build --platform ios --profile preview",
    "build:android:store": "npm run patch:eas-windows && eas build --platform android --profile production",
    "build:ios:store": "npm run patch:eas-windows && eas build --platform ios --profile production"
  },
  "dependencies": {
    "@react-native-async-storage/async-storage": "2.2.0",
    "@react-navigation/native": "^7.1.17",
    "@react-navigation/native-stack": "^7.3.26",
    "expo": "~54.0.0",
    "expo-av": "~16.0.7",
    "expo-linking": "~8.0.8",
    "expo-speech-recognition": "^3.1.3",
    "expo-status-bar": "~3.0.8",
    "react": "19.1.0",
    "react-native": "0.81.5",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-screens": "~4.16.0"
  },
  "devDependencies": {
    "@types/react": "~19.1.0",
    "eas-cli": "^19.0.5",
    "typescript": "~5.9.2"
  }
}
